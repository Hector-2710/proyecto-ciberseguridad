{
    "name": "Analyzer — Python 3.12 + Jupyter",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python"
            }
        }
    },
    "features": {
        "ghcr.io/devcontainers/features/git:1": {}
    },
    "remoteUser": "vscode"
}
